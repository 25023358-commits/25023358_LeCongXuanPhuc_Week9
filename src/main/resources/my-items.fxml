<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.auction.MyItemsController">
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox>
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0D3A26;" text="My Inventory" />
            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Manage and track your auction items" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleCreateItem" styleClass="btn-filled" style="-fx-background-color: #27ae60; -fx-padding: 8 20;" text="＋ Create New Item" />
    </HBox>
    <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="nameColumn" minWidth="120" prefWidth="150" text="Name" />
            <TableColumn fx:id="descColumn" minWidth="200" prefWidth="300" text="Description" />
            <TableColumn fx:id="priceColumn" minWidth="100" prefWidth="100" text="Starting Price" />
            <TableColumn fx:id="endTimeColumn" minWidth="150" prefWidth="150" text="End Time" />
            <TableColumn fx:id="actionColumn" minWidth="180" prefWidth="180" text="Action" />
        </columns>
    </TableView>
</VBox>
