<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.controller.auction.AuctionController"
      spacing="15" style="-fx-background-color: transparent; -fx-padding: 20;" stylesheets="@welcome-style.css">
    
    <!-- ===== HEADER ===== -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="Live Auctions Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER" spacing="10">
            <Label fx:id="userBalanceLabel" text="" 
                   style="-fx-font-size: 14px; -fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-background-color: white; -fx-padding: 8 15; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
            <Button fx:id="topUpButton" text="➕ Top Up" onAction="#handleTopUp" styleClass="btn-filled" style="-fx-padding: 5 15; -fx-pref-height: 35;"/>
        </HBox>
    </HBox>

    <!-- ===== MAIN CONTENT (2 COLUMNS) ===== -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        
        <!-- ================= LEFT COLUMN: DISCOVER (70%) ================= -->
        <VBox spacing="15" HBox.hgrow="ALWAYS">
            
            <!-- TABLE CARD -->
            <VBox VBox.vgrow="ALWAYS" spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 4); -fx-padding: 15;">
                
                <!-- FILTER BAR -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Search items by name..." prefWidth="250" style="-fx-pref-height: 35;"/>
                    <ComboBox fx:id="statusFilter" promptText="All Statuses" style="-fx-pref-height: 35; -fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                </HBox>
                
                <TableView fx:id="itemTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="nameColumn"        text="Item Name"    prefWidth="180"/>
                        <TableColumn fx:id="priceColumn"       text="Current Bid"  prefWidth="100"/>
                        <TableColumn fx:id="myStatusColumn"    text="My Status"    prefWidth="100"/>
                        <TableColumn fx:id="statusColumn"      text="Status"       prefWidth="80"/>
                        <TableColumn fx:id="endTimeColumn"     text="Ends In"      prefWidth="110"/>
                        <TableColumn fx:id="descriptionColumn" text="Description"  prefWidth="180"/>
                    </columns>
                    <placeholder>
                        <Label text="No auction items available." style="-fx-text-fill: #aaa;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- NOTIFICATIONS CARD -->
            <VBox spacing="8" prefHeight="150" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 4); -fx-padding: 15;">
                <Label text="🔔 Live Notifications" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <ListView fx:id="notificationList" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <placeholder>
                        <Label text="No notifications yet." style="-fx-text-fill: #aaa;"/>
                    </placeholder>
                </ListView>
            </VBox>

        </VBox>

        <!-- ================= RIGHT COLUMN: ACTION CENTER (30%) ================= -->
        <VBox prefWidth="350" spacing="15">
            
            <!-- BIDDING CARD -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 4); -fx-padding: 20;">
                
                <!-- Selected Item Header -->
                <VBox spacing="5">
                    <Label text="Currently Selected:" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                    <Text fx:id="selectedItemText" text="No item selected" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-fill: #2c3e50;"/>
                </VBox>
                
                <Separator/>

                <!-- Manual Bid -->
                <VBox spacing="10">
                    <Label text="Manual Bid" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <HBox spacing="10">
                        <TextField fx:id="bidAmountField" promptText="Amount ($)" HBox.hgrow="ALWAYS" style="-fx-pref-height: 35;"/>
                        <Button text="Place Bid" onAction="#handlePlaceBid" styleClass="btn-filled" style="-fx-pref-height: 35;"/>
                    </HBox>
                </VBox>

                <!-- Auto Bid -->
                <VBox spacing="10">
                    <Label text="Auto-Bid Setup" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <HBox spacing="10">
                        <TextField fx:id="maxBidField" promptText="Max ($)" HBox.hgrow="ALWAYS" style="-fx-pref-height: 35;"/>
                        <TextField fx:id="incrementField" promptText="Step ($)" HBox.hgrow="ALWAYS" style="-fx-pref-height: 35;"/>
                    </HBox>
                    <Button text="Start Auto-Bid" onAction="#handleAutoBid" maxWidth="Infinity" styleClass="btn-outline" style="-fx-pref-height: 35;"/>
                    <Label fx:id="autoBidStatusLabel" style="-fx-font-size: 11px; -fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
                </VBox>
                
                <Label fx:id="bidMessageLabel" wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #e74c3c;"/>
                
            </VBox>

            <!-- ANALYTICS CARD -->
            <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 4); -fx-padding: 15;">
                <Label text="📊 Price History" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <LineChart fx:id="priceChart" prefHeight="180" legendVisible="false" animated="false" style="-fx-padding: 0;">
                    <xAxis><CategoryAxis label="Time"/></xAxis>
                    <yAxis><NumberAxis label="Price ($)"/></yAxis>
                </LineChart>
                
                <Separator/>
                
                <Label text="📜 Bid History" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <ListView fx:id="bidHistoryList" prefHeight="150" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <placeholder>
                        <Label text="Select an item to view bids." style="-fx-text-fill: #aaa;"/>
                    </placeholder>
                </ListView>

                <Button fx:id="viewDetailsButton" text="🔍 View Full Details" onAction="#handleViewDetails" maxWidth="Infinity" styleClass="btn-filled" style="-fx-background-color: #2c3e50; -fx-effect: none; -fx-pref-height: 35;"/>
            </VBox>

        </VBox>

    </HBox>

</VBox>
