<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="450.0" prefHeight="400.0" spacing="10" style="-fx-padding: 20; -fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.auction.ItemDetailController">
    <Label fx:id="itemNameLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Item Name" />
    <Separator />
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="120" halignment="RIGHT" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <Label text="Status:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
        <Label fx:id="statusLabel" text="—" GridPane.rowIndex="0" GridPane.columnIndex="1" />
        
        <Label text="Seller:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
        <Label fx:id="sellerLabel" text="—" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        
        <Label text="Category:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
        <Label fx:id="categoryLabel" text="—" GridPane.rowIndex="2" GridPane.columnIndex="1" />
        
        <Label text="Starting Price:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
        <Label fx:id="startingPriceLabel" text="0.00" GridPane.rowIndex="3" GridPane.columnIndex="1" />
        
        <Label text="Current Bid:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
        <Label fx:id="currentBidLabel" text="0.00" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-text-fill: red; -fx-font-weight: bold;" />
        
        <Label text="Start Time:" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
        <Label fx:id="startTimeLabel" text="—" GridPane.rowIndex="6" GridPane.columnIndex="1" />
        
        <Label text="End Time:" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
        <Label fx:id="endTimeLabel" text="—" GridPane.rowIndex="7" GridPane.columnIndex="1" />
    </GridPane>
    
    <Label text="Description:" style="-fx-font-weight: bold;" />
    <Label fx:id="descriptionLabel" text="—" wrapText="true" minHeight="50" />
    
    <Label fx:id="extraInfoLabel" text="" style="-fx-font-style: italic; -fx-text-fill: gray;" />

    <Region VBox.vgrow="ALWAYS" />
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="bidCountLabel" text="0 bids" style="-fx-text-fill: gray;" />
        <Pane HBox.hgrow="ALWAYS" />
        <Button fx:id="btnPayNow" onAction="#handlePayNow" text="Pay Now" visible="false" managed="false" style="-fx-background-color: orange; -fx-text-fill: white;" />
        <Button onAction="#handleClose" text="Close" prefWidth="80" />
    </HBox>
</VBox>
