<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.DropShadow?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.LoginController"
           prefHeight="600" prefWidth="900" stylesheets="@welcome-style.css" styleClass="left-pane">

    <!-- Nền Gradient (Dùng chung style với màn hình Welcome) -->
    <Circle radius="200" styleClass="abstract-circle-1" StackPane.alignment="TOP_LEFT" translateX="-50" translateY="-50"/>
    <Circle radius="120" styleClass="abstract-circle-2" StackPane.alignment="BOTTOM_RIGHT" translateX="50" translateY="50"/>

    <!-- Centered Card (Khung trắng ở giữa) -->
    <HBox maxWidth="750" maxHeight="450" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);">

        <!-- Nửa trái: Ảnh minh họa (hoặc gradient/họa tiết sóng) -->
        <VBox prefWidth="300" alignment="CENTER" spacing="15" style="-fx-background-color: linear-gradient(to bottom, #2980b9, #6dd5ed); -fx-background-radius: 15 0 0 15; -fx-padding: 30;">
            <Text text="Welcome Back" style="-fx-fill: white; -fx-font-size: 32px; -fx-font-weight: bold; -fx-text-alignment: CENTER;" wrappingWidth="200"/>
            <Text text="Log in to access your auctions and bids." style="-fx-fill: white; -fx-font-size: 14px; -fx-text-alignment: CENTER;" wrappingWidth="200"/>
        </VBox>

        <!-- Nửa phải: Form Đăng nhập -->
        <VBox prefWidth="450" alignment="CENTER" spacing="20" style="-fx-padding: 40;">
            <Label text="Sign In" styleClass="form-title" style="-fx-padding: 0 0 10 0;"/>

            <!-- Form fields dàn dọc -->
            <VBox spacing="5" maxWidth="300">
                <Label text="Username" style="-fx-text-fill: #7f8c8d;"/>
                <TextField fx:id="usernameField" promptText="Enter your username" style="-fx-background-radius: 8; -fx-padding: 10;"/>
            </VBox>

            <VBox spacing="5" maxWidth="300">
                <Label text="Password" style="-fx-text-fill: #7f8c8d;"/>
                <!-- StackPane để chứa cả ô Password và ô Text thường -->
                <StackPane>
                    <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-background-radius: 8; -fx-padding: 10;"/>
                    <TextField fx:id="visiblePasswordField" managed="false" visible="false" promptText="Enter your password" style="-fx-background-radius: 8; -fx-padding: 10;"/>
                </StackPane>
            </VBox>

            <HBox alignment="CENTER_RIGHT" maxWidth="300">
                 <CheckBox fx:id="showPasswordCheckBox" text="Show Password" styleClass="check-box"/>
            </HBox>

            <!-- Login Button -->
            <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin" styleClass="btn-filled" prefWidth="300" prefHeight="40"/>

            <Label fx:id="messageLabel" textFill="RED" wrapText="true" style="-fx-font-size: 12px; -fx-padding: 10 0 0 0;"/>

            <HBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                <Label text="Don't have an account? " style="-fx-text-fill: #7f8c8d;"/>
                <Hyperlink text="Sign Up" onAction="#switchToRegister" style="-fx-text-fill: #2980b9; -fx-font-weight: bold; -fx-padding: 0;"/>
            </HBox>
        </VBox>
    </HBox>
</StackPane>